From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Kanaka Raju Nayana <kanaka.raju.nayana@intel.com>
Date: Thu, 14 May 2026 01:28:02 +0530
Subject: drm/xe: make drm_exec dependency conditional on kernel
 version

make drm_exec dependency conditional on kernel version

Signed-off-by: Kanaka Raju Nayana <kanaka.raju.nayana@intel.com>
---
 drivers/gpu/drm/xe/Kconfig | 7 ++++++-
 1 file changed, 6 insertions(+), 1 deletion(-)

diff --git a/drivers/gpu/drm/xe/Kconfig b/drivers/gpu/drm/xe/Kconfig
index dfc99fc..baa1e58 100644
--- a/drivers/gpu/drm/xe/Kconfig
+++ b/drivers/gpu/drm/xe/Kconfig
@@ -1,4 +1,9 @@
 # SPDX-License-Identifier: GPL-2.0-only
+config DRM_EXEC
+        tristate
+        depends on m
+        depends on DRM
+        depends on BUILD_XE_DRM_EXEC
 config DRM_GPUVM
 	tristate "Enable Xe-specific DRM GPUVM support"
 	depends on DRM
@@ -46,7 +51,7 @@ config DRM_XE
 	select VMAP_PFN
 	select DRM_TTM
 	select DRM_TTM_HELPER
-	select DRM_EXEC
+	select DRM_EXEC if BUILD_XE_DRM_EXEC
 	select DRM_GPUVM if BUILD_XE_DRM_GPUVM
 	select DRM_SCHED
 	select MMU_NOTIFIER
-- 
2.43.0

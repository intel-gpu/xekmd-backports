From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Kanaka Raju Nayana <kanaka.raju.nayana@intel.com>
Date: Fri, 15 May 2026 16:55:17 +0530
Subject: xe/migrate: guard iosys_map include for old kernels

Use HAVE_LINUX_IOSYS_MAP_H in xe_migrate.h to include iosys-map.h
when available, and fall back to dma-buf-map.h otherwise. This keeps
iosys_map prototypes consistent across 5.15 kernels.

Signed-off-by: Kanaka Raju Nayana <kanaka.raju.nayana@intel.com>
---
 drivers/gpu/drm/xe/xe_migrate.h | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/drivers/gpu/drm/xe/xe_migrate.h b/drivers/gpu/drm/xe/xe_migrate.h
index cf99213..51f0bcb 100644
--- a/drivers/gpu/drm/xe/xe_migrate.h
+++ b/drivers/gpu/drm/xe/xe_migrate.h
@@ -8,6 +8,13 @@
 
 #include <linux/types.h>
 
+#ifdef HAVE_LINUX_IOSYS_MAP_H
+#include <linux/iosys-map.h>
+#else
+#include <linux/dma-buf-map.h>
+#define iosys_map dma_buf_map
+#endif
+
 struct dma_fence;
 struct iosys_map;
 struct ttm_resource;
-- 

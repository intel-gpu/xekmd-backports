From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Akanksha Hotta <akanksha.hotta@intel.com>
Date: Sun, 26 Apr 2026 21:06:42 +0530
Subject: Introduce ACQUIRE() and ACQUIRE_ERR() for conditional locks

ACQUIRE and ACQUIRE_ERR cleanup guard macros in v7.0 as part of the
cleanup.h infrastructure for automatic resource management. The xe driver
uses these for PM runtime locking in ioctl handlers.

Implemented autoconf detection and conditional fallback pattern to detect
ACQUIRE macro availability via cleanup.h compilation probe.

Reference:
   857d18f23ab1
   cleanup: Introduce ACQUIRE() and ACQUIRE_ERR() for conditional locks

Signed-off-by: Akanksha Hotta <akanksha.hotta@intel.com>
---
 drivers/gpu/drm/xe/xe_device.c | 20 ++++++++++++++++++++
 1 file changed, 20 insertions(+)

diff --git a/drivers/gpu/drm/xe/xe_device.c b/drivers/gpu/drm/xe/xe_device.c
index 55a9058..7547f15 100644
--- a/drivers/gpu/drm/xe/xe_device.c
+++ b/drivers/gpu/drm/xe/xe_device.c
@@ -241,6 +241,15 @@ static long xe_drm_ioctl(struct file *file, unsigned int cmd, unsigned long arg)
 	if (xe_device_wedged(xe))
 		return -ECANCELED;
 
+#ifdef BPM_ACQUIRE_MACRO_NOT_PRESENT
+	ret = xe_pm_runtime_get_ioctl(xe);
+	if (ret >= 0) {
+		xe_eudebug_discovery_lock(xe, cmd);
+		ret = drm_ioctl(file, cmd, arg);
+		xe_eudebug_discovery_unlock(xe, cmd);
+		xe_pm_runtime_put(xe);
+	}
+#else
 	ACQUIRE(xe_pm_runtime_ioctl, pm)(xe);
 	ret = ACQUIRE_ERR(xe_pm_runtime_ioctl, &pm);
 	if (ret >= 0) {
@@ -248,6 +257,7 @@ static long xe_drm_ioctl(struct file *file, unsigned int cmd, unsigned long arg)
 		ret = drm_ioctl(file, cmd, arg);
 		xe_eudebug_discovery_unlock(xe, cmd);
 	}
+#endif
 
 	return ret;
 }
@@ -262,6 +272,15 @@ static long xe_drm_compat_ioctl(struct file *file, unsigned int cmd, unsigned lo
 	if (xe_device_wedged(xe))
 		return -ECANCELED;
 
+#ifdef BPM_ACQUIRE_MACRO_NOT_PRESENT
+	ret = xe_pm_runtime_get_ioctl(xe);
+	if (ret >= 0) {
+		xe_eudebug_discovery_lock(xe, cmd);
+		ret = drm_compat_ioctl(file, cmd, arg);
+		xe_eudebug_discovery_unlock(xe, cmd);
+		xe_pm_runtime_put(xe);
+	}
+#else
 	ACQUIRE(xe_pm_runtime_ioctl, pm)(xe);
 	ret = ACQUIRE_ERR(xe_pm_runtime_ioctl, &pm);
 	if (ret >= 0) {
@@ -269,6 +288,7 @@ static long xe_drm_compat_ioctl(struct file *file, unsigned int cmd, unsigned lo
 		ret = drm_compat_ioctl(file, cmd, arg);
 		xe_eudebug_discovery_unlock(xe, cmd);
 	}
+#endif
 
 	return ret;
 }

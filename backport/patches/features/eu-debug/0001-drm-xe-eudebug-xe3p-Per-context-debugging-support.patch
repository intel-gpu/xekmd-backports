+static int send_sync_host_event(struct xe_eudebug *d,
+				struct xe_exec_queue *q,
+				struct xe_lrc *lrc)
+{
+	struct xe_eudebug_event_sync_host *es;
+	struct xe_eudebug_event *event;
+	int h_c, h_queue, h_lrc;
+	u64 seqno;
+
+	h_c = find_handle(d->res, XE_EUDEBUG_RES_TYPE_CLIENT, q->vm->xef);
+	if (h_c < 0)
+		return h_c;
+
+	h_queue = find_handle(d->res, XE_EUDEBUG_RES_TYPE_EXEC_QUEUE, q);
+	if (h_queue < 0)
+		return h_queue;
+
+	h_lrc = find_handle(d->res, XE_EUDEBUG_RES_TYPE_LRC, lrc);
+	if (h_lrc < 0)
+		return h_lrc;
+
+	seqno = atomic_long_inc_return(&d->events.seqno);
+
+	event = xe_eudebug_create_event(d, DRM_XE_EUDEBUG_EVENT_SYNC_HOST, seqno,
+					DRM_XE_EUDEBUG_EVENT_STATE_CHANGE,
+					sizeof(*es));
+
+	if (!event)
+		return -ENOSPC;
+
+	es = cast_event(es, event);
+	write_member(struct drm_xe_eudebug_event_sync_host, es, client_handle, (u64)h_c);
+	write_member(struct drm_xe_eudebug_event_sync_host, es, exec_queue_handle, (u64)h_queue);
+	write_member(struct drm_xe_eudebug_event_sync_host, es, lrc_handle, (u64)h_lrc);
+
+	return xe_eudebug_queue_event(d, event);
+}
+
+int xe_eudebug_sync_host(struct xe_exec_queue *q, struct xe_lrc *lrc)
+{
+	struct xe_device *xe = gt_to_xe(q->gt);
+	struct xe_eudebug *d;
+	int err;
+
+	down_read(&xe->eudebug.discovery_lock);
+
+	d = xe_eudebug_get(q->vm->xef);
+	if (!d) {
+		up_read(&xe->eudebug.discovery_lock);
+		return -EINVAL;
+	}
+
+	err = send_sync_host_event(d, q, lrc);
+	if (err) {
+		eu_err(d, "error %d on %s, disconnecting", err, __func__);
+		xe_eudebug_disconnect(d, err);
+	}
+
+	xe_eudebug_put(d);
+	up_read(&xe->eudebug.discovery_lock);
+
+	return err;
+}

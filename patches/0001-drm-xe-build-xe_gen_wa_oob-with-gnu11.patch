From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Kanaka Raju Nayana <kanaka.raju.nayana@intel.com>
Date: Thu, 14 May 2026 02:25:57 +0530
Subject: drm/xe: build xe_gen_wa_oob with gnu11

Fix host-tool build failure on older default C modes by compiling
xe_gen_wa_oob with -std=gnu11.

Signed-off-by: Kanaka Raju Nayana <kanaka.raju.nayana@intel.com>
---
 drivers/gpu/drm/xe/Makefile | 1 +
 1 file changed, 1 insertion(+)

diff --git a/drivers/gpu/drm/xe/Makefile b/drivers/gpu/drm/xe/Makefile
index 3123674..eb263de 100644
--- a/drivers/gpu/drm/xe/Makefile
+++ b/drivers/gpu/drm/xe/Makefile
@@ -14,6 +14,7 @@ subdir-ccflags-y += -I$(obj) -I$(src)
 # generated sources
 
 hostprogs := xe_gen_wa_oob
+HOSTCFLAGS_xe_gen_wa_oob.o := -std=gnu11
 generated_oob := $(obj)/generated/xe_wa_oob.c $(obj)/generated/xe_wa_oob.h
 quiet_cmd_wa_oob = GEN     $(notdir $(generated_oob))
       cmd_wa_oob = mkdir -p $(@D); $^ $(generated_oob)
-- 

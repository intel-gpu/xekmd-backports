From: Varun Gupta <varun.gupta@intel.com>
Subject: [PATCH] drm/xe/bo: guard drm_mode_size_dumb for older kernels

drm_mode_size_dumb() was introduced in v7.0. On older kernels, compute
pitch/size inline (same arithmetic as drm_mode_size_dumb() implementation
with min_pitch_align=SZ_64 and page_size_align=page_size).

Signed-off-by: Varun Gupta <varun.gupta@intel.com>
---
 drivers/gpu/drm/xe/xe_bo.c | 13 +++++++++++++
 1 file changed, 13 insertions(+)

diff --git a/drivers/gpu/drm/xe/xe_bo.c b/drivers/gpu/drm/xe/xe_bo.c
--- a/drivers/gpu/drm/xe/xe_bo.c
+++ b/drivers/gpu/drm/xe/xe_bo.c
@@ -11,4 +11,6 @@
 #include <drm/drm_drv.h>
+#ifndef BPM_DRM_MODE_SIZE_DUMB_NOT_PRESENT
 #include <drm/drm_dumb_buffers.h>
+#endif
 #include <drm/drm_gem_ttm_helper.h>
 #include <drm/drm_managed.h>
@@ -3636,6 +3638,16 @@ int xe_bo_dumb_create(struct drm_file *file_priv,
 		xe->info.vram_flags & XE_VRAM_FLAGS_NEED64K ? SZ_64K : SZ_4K);
 
+#ifdef BPM_DRM_MODE_SIZE_DUMB_NOT_PRESENT
+	{
+		int cpp = DIV_ROUND_UP(args->bpp, 8);
+
+		args->pitch = ALIGN(args->width * cpp, 64);
+		args->size = ALIGN(mul_u32_u32(args->pitch, args->height),
+				   page_size);
+	}
+#else
 	err = drm_mode_size_dumb(dev, args, SZ_64, page_size);
 	if (err)
 		return err;
+#endif
 
-- 

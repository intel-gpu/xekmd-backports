From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Kanaka Raju Nayana <kanaka.raju.nayana@intel.com>
Date: Tue, 19 May 2026 17:00:06 +0530
Subject: drm/xe: Enable drm_suballoc module for 5.15

Enable drm_suballoc module for 5.15.

Signed-off-by: Kanaka Raju Nayana <kanaka.raju.nayana@intel.com>
---
 drivers/gpu/drm/xe/Kconfig | 7 ++++++-
 1 file changed, 6 insertions(+), 1 deletion(-)

diff --git a/drivers/gpu/drm/xe/Kconfig b/drivers/gpu/drm/xe/Kconfig
index 259cb08..0f2734d 100644
--- a/drivers/gpu/drm/xe/Kconfig
+++ b/drivers/gpu/drm/xe/Kconfig
@@ -1,4 +1,9 @@
 # SPDX-License-Identifier: GPL-2.0-only
+config DRM_SUBALLOC_HELPER
+        tristate
+	depends on m
+        depends on DRM
+        depends on BUILD_XE_DRM_SUBALLOC_HELPER
 config DRM_BUDDY
         tristate
         depends on m
@@ -34,7 +39,7 @@ config DRM_XE
 	#select DRM_KMS_HELPER
 	select DRM_KUNIT_TEST_HELPERS if DRM_XE_KUNIT_TEST != n
 	#select DRM_PANEL
-	select DRM_SUBALLOC_HELPER
+	select DRM_SUBALLOC_HELPER if BUILD_XE_DRM_SUBALLOC_HELPER
 	#select DRM_DISPLAY_DP_HELPER
 	#select DRM_DISPLAY_DSC_HELPER
 	#select DRM_DISPLAY_HDCP_HELPER
-- 
2.43.0

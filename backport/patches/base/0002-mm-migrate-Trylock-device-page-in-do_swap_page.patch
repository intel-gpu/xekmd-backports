From 63e84d4344319e9e852c03cdeb213ab2f828fb72 Mon Sep 17 00:00:00 2001
From: Matthew Brost <matthew.brost@intel.com>
Date: Tue, 12 May 2026 10:18:33 +0530
Subject: [PATCH 2/3] mm/migrate: Trylock device page in do_swap_page
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Avoid multiple CPU page faults to the same device page racing by trying
to lock the page in do_swap_page before taking an extra reference to the
page. This prevents scenarios where multiple CPU page faults each take
an extra reference to a device page, which could abort migration in
folio_migrate_mapping. With the device page being locked in
do_swap_page, the migrate_vma_* functions need to be updated to avoid
locking the fault_page argument.

Prior to this change, a livelock scenario could occur in Xe's (Intel GPU
DRM driver) SVM implementation if enough threads faulted the same device
page.

v3:
 - Put page after unlocking page (Alistair)
 - Warn on spliting a TPH which is fault page (Alistair)
 - Warn on dst page == fault page (Alistair)
v6:
 - Add more verbose comment around THP (Alistair)
v7:
 - Fix migrate_device_finalize alignment (Checkpatch)

Cc: Alistair Popple <apopple@nvidia.com>
Cc: Philip Yang <Philip.Yang@amd.com>
Cc: Felix Kuehling <felix.kuehling@amd.com>
Cc: Christian König <christian.koenig@amd.com>
Cc: Andrew Morton <akpm@linux-foundation.org>
Suggested-by: Simona Vetter <simona.vetter@ffwll.ch>
Signed-off-by: Matthew Brost <matthew.brost@intel.com>
Reviewed-by: Alistair Popple <apopple@nvidia.com>
Tested-by: Alistair Popple <apopple@nvidia.com>
Link: https://patchwork.freedesktop.org/patch/msgid/20250306012657.3505757-4-matthew.brost@intel.com
[ Backported to 6.6: migrate_vma_collect_pmd(), migrate_device_unmap(),
  migrate_vma_setup() and __migrate_device_finalize() adapted to use
  page-based API (trylock_page, unlock_page, put_page) and page-based
  fault_page checks instead of folio API not present in v6.6. - Varun Gupta ]
(cherry-picked from commit 1afaeb8293c9addbf4f9140bdd22635fed763459 linux)
Signed-off-by: Varun Gupta <varun.gupta@intel.com>
---
 mm/memory.c         | 13 +++++++++----
 mm/migrate_device.c | 46 ++++++++++++++++++++++++++++++++++++++-------
 2 files changed, 48 insertions(+), 11 deletions(-)

diff --git a/mm/memory.c b/mm/memory.c
index fd917a5bc961..795b3b9b4b2f 100644
--- a/mm/memory.c
+++ b/mm/memory.c
@@ -3784,10 +3784,15 @@ vm_fault_t do_swap_page(struct vm_fault *vmf)
 			 * Get a page reference while we know the page can't be
 			 * freed.
 			 */
-			get_page(vmf->page);
-			pte_unmap_unlock(vmf->pte, vmf->ptl);
-			ret = vmf->page->pgmap->ops->migrate_to_ram(vmf);
-			put_page(vmf->page);
+			if (trylock_page(vmf->page)) {
+				get_page(vmf->page);
+				pte_unmap_unlock(vmf->pte, vmf->ptl);
+				ret = vmf->page->pgmap->ops->migrate_to_ram(vmf);
+				unlock_page(vmf->page);
+				put_page(vmf->page);
+			} else {
+				pte_unmap_unlock(vmf->pte, vmf->ptl);
+			}
 		} else if (is_hwpoison_entry(entry)) {
 			ret = VM_FAULT_HWPOISON;
 		} else if (is_pte_marker_entry(entry)) {
diff --git a/mm/migrate_device.c b/mm/migrate_device.c
index 8eace07de568..a644def79aeb 100644
--- a/mm/migrate_device.c
+++ b/mm/migrate_device.c
@@ -60,6 +60,7 @@ static int migrate_vma_collect_pmd(pmd_t *pmdp,
 				   struct mm_walk *walk)
 {
 	struct migrate_vma *migrate = walk->private;
+	struct page *fault_page = migrate->fault_page;
 	struct vm_area_struct *vma = walk->vma;
 	struct mm_struct *mm = vma->vm_mm;
 	unsigned long addr = start, unmapped = 0;
@@ -88,11 +89,16 @@ static int migrate_vma_collect_pmd(pmd_t *pmdp,
 
 			get_page(page);
 			spin_unlock(ptl);
+			/* FIXME: we don't expect THP for fault_page */
+			if (WARN_ON_ONCE(fault_page == page))
+				return migrate_vma_collect_skip(start, end,
+								walk);
 			if (unlikely(!trylock_page(page)))
 				return migrate_vma_collect_skip(start, end,
 								walk);
 			ret = split_huge_page(page);
-			unlock_page(page);
+			if (fault_page != page)
+				unlock_page(page);
 			put_page(page);
 			if (ret)
 				return migrate_vma_collect_skip(start, end,
@@ -190,7 +196,7 @@ static int migrate_vma_collect_pmd(pmd_t *pmdp,
 		 * optimisation to avoid walking the rmap later with
 		 * try_to_migrate().
 		 */
-		if (trylock_page(page)) {
+		if (fault_page == page || trylock_page(page)) {
 			bool anon_exclusive;
 			pte_t swp_pte;
 
@@ -201,7 +207,8 @@ static int migrate_vma_collect_pmd(pmd_t *pmdp,
 
 				if (page_try_share_anon_rmap(page)) {
 					set_pte_at(mm, addr, ptep, pte);
-					unlock_page(page);
+					if (fault_page != page)
+						unlock_page(page);
 					put_page(page);
 					mpfn = 0;
 					goto next;
@@ -422,7 +429,8 @@ static unsigned long migrate_device_unmap(unsigned long *src_pfns,
 		remove_migration_ptes(folio, folio, false);
 
 		src_pfns[i] = 0;
-		folio_unlock(folio);
+		if (fault_page != page)
+			folio_unlock(folio);
 		folio_put(folio);
 		restore--;
 	}
@@ -531,6 +539,8 @@ int migrate_vma_setup(struct migrate_vma *args)
 		return -EINVAL;
 	if (args->fault_page && !is_device_private_page(args->fault_page))
 		return -EINVAL;
+	if (args->fault_page && !PageLocked(args->fault_page))
+		return -EINVAL;
 
 	memset(args->src, 0, sizeof(*args->src) * nr_pages);
 	args->cpages = 0;
@@ -808,8 +818,10 @@ EXPORT_SYMBOL(migrate_vma_pages);
  * Drivers must ensure copying of page data is complete and visible to the CPU
  * before calling this.
  */
-void migrate_device_finalize(unsigned long *src_pfns,
-			unsigned long *dst_pfns, unsigned long npages)
+static void __migrate_device_finalize(unsigned long *src_pfns,
+				     unsigned long *dst_pfns,
+				     unsigned long npages,
+				     struct page *fault_page)
 {
 	unsigned long i;
 
@@ -823,6 +835,7 @@ void migrate_device_finalize(unsigned long *src_pfns,
 
 		if (!page) {
 			if (dst) {
+				WARN_ON_ONCE(fault_page == newpage);
 				folio_unlock(dst);
 				folio_put(dst);
 			}
@@ -833,6 +846,7 @@ void migrate_device_finalize(unsigned long *src_pfns,
 
 		if (!(src_pfns[i] & MIGRATE_PFN_MIGRATE) || !dst) {
 			if (dst) {
+				WARN_ON_ONCE(fault_page == newpage);
 				folio_unlock(dst);
 				folio_put(dst);
 			}
@@ -842,15 +856,33 @@ void migrate_device_finalize(unsigned long *src_pfns,
 		if (!folio_is_zone_device(dst))
 			folio_add_lru(dst);
 		remove_migration_ptes(src, dst, false);
-		folio_unlock(src);
+		if (fault_page != page)
+			folio_unlock(src);
 		folio_put(src);
 
 		if (dst != src) {
+			WARN_ON_ONCE(fault_page == newpage);
 			folio_unlock(dst);
 			folio_put(dst);
 		}
 	}
 }
+
+/*
+ * migrate_device_finalize() - complete page migration
+ * @src_pfns: src_pfns returned from migrate_device_range()
+ * @dst_pfns: array of pfns allocated by the driver to migrate memory to
+ * @npages: number of pages in the range
+ *
+ * Completes migration of the page by removing special migration entries.
+ * Drivers must ensure copying of page data is complete and visible to the CPU
+ * before calling this.
+ */
+void migrate_device_finalize(unsigned long *src_pfns,
+			unsigned long *dst_pfns, unsigned long npages)
+{
+	return __migrate_device_finalize(src_pfns, dst_pfns, npages, NULL);
+}
 EXPORT_SYMBOL(migrate_device_finalize);
 
 /**

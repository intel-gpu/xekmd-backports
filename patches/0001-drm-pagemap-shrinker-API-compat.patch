From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Varun Gupta <varun.gupta1@intel.com>
Date: Mon, 27 Apr 2026 10:30:00 +0530
Subject: [PATCH] drm/pagemap: Provide compat for shrinker_alloc() API on
 older kernels

The dynamic shrinker API (shrinker_alloc()/shrinker_register()/
shrinker_free() + ->private_data) was introduced in v6.7:

  c42d50aefd17 mm: shrinker: add infrastructure for dynamically allocating
               shrinker

Older kernels only provide the legacy register_shrinker()/
unregister_shrinker() API with an embedded struct shrinker.

Use BPM_SHRINKER_ALLOC_NOT_PRESENT (detected at configure time by
autotools/m4/shrinker_alloc.m4) to switch struct drm_pagemap_shrinker
to embed a struct shrinker in-place and use the legacy register API.
The callbacks recover the wrapper via container_of() instead of
->private_data.

This keeps drm_pagemap shrinking functional on 6.6 LTS kernels.

Signed-off-by: Varun Gupta <varun.gupta1@intel.com>
---
 drivers/gpu/drm/drm_pagemap_util.c | 36 ++++++++++++++++++++++++++++++
 1 file changed, 36 insertions(+)

diff --git a/drivers/gpu/drm/drm_pagemap_util.c b/drivers/gpu/drm/drm_pagemap_util.c
--- a/drivers/gpu/drm/drm_pagemap_util.c
+++ b/drivers/gpu/drm/drm_pagemap_util.c
@@ -51,8 +51,13 @@ struct drm_pagemap_shrinker {
 	struct list_head dpagemaps;
 	/** @num_dpagemaps: Number of unused dpagemaps in @dpagemaps. */
 	atomic_t num_dpagemaps;
+#ifdef BPM_SHRINKER_ALLOC_NOT_PRESENT
+	/** @compat_shrink: Embedded shrinker for old register_shrinker() API. */
+	struct shrinker compat_shrink;
+#else
 	/** @shrink: Pointer to the struct shrinker. */
 	struct shrinker *shrink;
+#endif
 };
 
 static bool drm_pagemap_shrinker_cancel(struct drm_pagemap *dpagemap);
@@ -350,7 +355,12 @@ drm_pagemap_shrinker_drm_unregister(struct drm_pagemap *dpagemap)
 static unsigned long
 drm_pagemap_shrinker_count(struct shrinker *shrink, struct shrink_control *sc)
 {
+#ifdef BPM_SHRINKER_ALLOC_NOT_PRESENT
+	struct drm_pagemap_shrinker *shrinker =
+		container_of(shrink, struct drm_pagemap_shrinker, compat_shrink);
+#else
 	struct drm_pagemap_shrinker *shrinker = shrink->private_data;
+#endif
 	unsigned long count = atomic_read(&shrinker->num_dpagemaps);
 
 	return count ? : SHRINK_EMPTY;
@@ -359,7 +369,12 @@ drm_pagemap_shrinker_count(struct shrinker *shrink, struct shrink_control *sc)
 static unsigned long
 drm_pagemap_shrinker_scan(struct shrinker *shrink, struct shrink_control *sc)
 {
+#ifdef BPM_SHRINKER_ALLOC_NOT_PRESENT
+	struct drm_pagemap_shrinker *shrinker =
+		container_of(shrink, struct drm_pagemap_shrinker, compat_shrink);
+#else
 	struct drm_pagemap_shrinker *shrinker = shrink->private_data;
+#endif
 	struct drm_pagemap *dpagemap;
 	struct drm_pagemap_cache *cache;
 	unsigned long nr_freed = 0;
@@ -399,7 +414,11 @@ static void drm_pagemap_shrinker_fini(void *arg)
 
 	drm_dbg(shrinker->drm, "Destroying dpagemap shrinker.\n");
 	drm_WARN_ON(shrinker->drm, !!atomic_read(&shrinker->num_dpagemaps));
+#ifdef BPM_SHRINKER_ALLOC_NOT_PRESENT
+	unregister_shrinker(&shrinker->compat_shrink);
+#else
 	shrinker_free(shrinker->shrink);
+#endif
 	kfree(shrinker);
 }
 
@@ -417,13 +436,29 @@ static void drm_pagemap_shrinker_fini(void *arg)
 struct drm_pagemap_shrinker *drm_pagemap_shrinker_create_devm(struct drm_device *drm)
 {
 	struct drm_pagemap_shrinker *shrinker;
+#ifndef BPM_SHRINKER_ALLOC_NOT_PRESENT
 	struct shrinker *shrink;
+#endif
 	int err;
 
 	shrinker = kzalloc_obj(*shrinker);
 	if (!shrinker)
 		return ERR_PTR(-ENOMEM);
 
+#ifdef BPM_SHRINKER_ALLOC_NOT_PRESENT
+	spin_lock_init(&shrinker->lock);
+	INIT_LIST_HEAD(&shrinker->dpagemaps);
+	shrinker->drm = drm;
+	shrinker->compat_shrink.count_objects = drm_pagemap_shrinker_count;
+	shrinker->compat_shrink.scan_objects = drm_pagemap_shrinker_scan;
+	shrinker->compat_shrink.seeks = DEFAULT_SEEKS;
+	err = register_shrinker(&shrinker->compat_shrink,
+				"drm-drm_pagemap:%s", drm->unique);
+	if (err) {
+		kfree(shrinker);
+		return ERR_PTR(err);
+	}
+#else
 	shrink = shrinker_alloc(0, "drm-drm_pagemap:%s", drm->unique);
 	if (!shrink) {
 		kfree(shrinker);
@@ -438,6 +473,7 @@ struct drm_pagemap_shrinker *drm_pagemap_shrinker_create_devm(struct drm_device
 	shrink->scan_objects = drm_pagemap_shrinker_scan;
 	shrink->private_data = shrinker;
 	shrinker_register(shrink);
+#endif
 
 	err = devm_add_action_or_reset(drm->dev, drm_pagemap_shrinker_fini, shrinker);
 	if (err)
-- 
2.43.0


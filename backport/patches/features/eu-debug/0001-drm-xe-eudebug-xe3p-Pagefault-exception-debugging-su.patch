 drivers/gpu/drm/xe/regs/xe_lrc_layout.h  |  2 ++
 drivers/gpu/drm/xe/xe_eudebug.c          |  3 +++
 drivers/gpu/drm/xe/xe_exec_queue.c       | 16 ++++++++++++----
 drivers/gpu/drm/xe/xe_exec_queue_types.h |  3 ++-
 drivers/gpu/drm/xe/xe_lrc.c              |  7 +++++--

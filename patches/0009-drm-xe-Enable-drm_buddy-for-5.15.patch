From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Kanaka Raju Nayana <kanaka.raju.nayana@intel.com>
Date: Thu, 14 May 2026 01:58:02 +0530
Subject: drm/xe: Enable drm_buddy for 5.15

Enable drm_buddy module.

Signed-off-by: Kanaka Raju Nayana <kanaka.raju.nayana@intel.com>
---
 drivers/gpu/drm/xe/Kconfig | 7 ++++++-
 1 file changed, 6 insertions(+), 1 deletion(-)

diff --git a/drivers/gpu/drm/xe/Kconfig b/drivers/gpu/drm/xe/Kconfig
index baa1e58..1b2c18c 100644
--- a/drivers/gpu/drm/xe/Kconfig
+++ b/drivers/gpu/drm/xe/Kconfig
@@ -1,4 +1,9 @@
 # SPDX-License-Identifier: GPL-2.0-only
+config DRM_BUDDY
+        tristate
+        depends on m
+        depends on DRM
+        depends on BUILD_XE_DRM_BUDDY
 config DRM_EXEC
         tristate
         depends on m
@@ -24,7 +29,7 @@ config DRM_XE
 	# the shmem_readpage() which depends upon tmpfs
 	select SHMEM
 	select TMPFS
-	select DRM_BUDDY
+	select DRM_BUDDY if BUILD_XE_DRM_BUDDY
 	#select DRM_CLIENT_SELECTION
 	#select DRM_KMS_HELPER
 	select DRM_KUNIT_TEST_HELPERS if DRM_XE_KUNIT_TEST != n
-- 
